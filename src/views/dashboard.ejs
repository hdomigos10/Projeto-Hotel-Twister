<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Hotel Twister</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">🏨 Hotel Twister</a>
            <span class="navbar-text text-white me-3">Olá, <%= usuario.nome %></span>
            <a href="/logout" class="btn btn-danger btn-sm">Sair</a>
        </div>
    </nav>
    <div class="container text-center mt-5">
        <div class="jumbotron bg-white p-5 rounded shadow-sm">
            <h1 class="display-4">Painel de Controle</h1>
            <p class="lead">Bem-vindo ao sistema de gerenciamento de hospedagem do Hotel Twister.</p>
            <hr class="my-4">
            <div class="d-flex justify-content-center gap-3">
                <a href="/hospedes" class="btn btn-primary btn-lg">👥 Gerenciar Hóspedes</a>
                <a href="/quartos" class="btn btn-success btn-lg">🛏️ Gerenciar Quartos</a>
                <a href="/reservas" class="btn btn-dark btn-lg">🔑 Gerenciar Reservas</a>
            </div>
        </div>
    </div>
</body>
</html>