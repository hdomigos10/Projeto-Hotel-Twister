<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><title>Reservas - Hotel Twister</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4"><div class="container"><a class="navbar-brand" href="/dashboard">🏨 Hotel Twister</a><a href="/logout" class="btn btn-danger btn-sm">Sair</a></div></nav>
    <div class="container">
        <div class="d-flex justify-content-between mb-3"><h2>Gerenciamento de Reservas</h2><a href="/reservas/novo" class="btn btn-primary">➕ Nova Reserva</a></div>
        <table class="table table-striped table-hover shadow-sm bg-white rounded">
            <thead class="table-dark"><tr><th>Hóspede</th><th>Quarto</th><th>Entrada</th><th>Saída</th><th>Valor Total</th><th>Ações</th></tr></thead>
            <tbody>
                <% if (reservas.length === 0) { %>
                    <tr><td colspan="6" class="text-center text-muted">Nenhuma reserva cadastrada.</td></tr>
                <% } %>
                <% reservas.forEach(r => { %>
                    <tr>
                        <td><%= r.hospede_nome %></td>
                        <td><%= r.quarto_numero %></td>
                        <td><%= new Date(r.data_entrada).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %></td>
                        <td><%= new Date(r.data_saida).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %></td>
                        <td>R$ <%= Number(r.valor_total).toFixed(2) %></td>
                        <td>
                            <a href="/reservas/editar/<%= r.id_reserva %>" class="btn btn-sm btn-warning">Editar</a>
                            <a href="/reservas/excluir/<%= r.id_reserva %>" class="btn btn-sm btn-danger" onclick="return confirm('Confirmar exclusão? O quarto voltará a ficar disponível.')">Excluir</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
