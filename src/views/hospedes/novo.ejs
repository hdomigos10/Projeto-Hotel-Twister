<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><title>Novo Hóspede - Hotel Twister</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow-sm mx-auto" style="max-width: 500px;">
            <div class="card-header bg-primary text-white"><h5>➕ Cadastrar Hóspede</h5></div>
            <div class="card-body">
                <form action="/hospedes/novo" method="POST">
                    <div class="mb-3"><label class="form-label">Nome Completo</label><input type="text" name="nome" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label">CPF</label><input type="text" name="cpf" class="form-control" placeholder="111.222.333-44" required></div>
                    <div class="mb-3"><label class="form-label">E-mail</label><input type="email" name="email" class="form-control"></div>
                    <div class="mb-3"><label class="form-label">Telefone</label><input type="text" name="telefone" class="form-control"></div>
                    <div class="d-flex justify-content-between"><a href="/hospedes" class="btn btn-secondary">Voltar</a><button type="submit" class="btn btn-success">Salvar</button></div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>