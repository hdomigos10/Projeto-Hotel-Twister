<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><title>Editar Hóspede - Hotel Twister</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow-sm mx-auto" style="max-width: 500px;">
            <div class="card-header bg-warning text-dark"><h5>✏️ Editar Hóspede</h5></div>
            <div class="card-body">
                <form action="/hospedes/editar/<%= hospede.id_hospede %>" method="POST">
                    <div class="mb-3"><label class="form-label">Nome Completo</label><input type="text" name="nome" value="<%= hospede.nome %>" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label">CPF</label><input type="text" name="cpf" value="<%= hospede.cpf %>" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label">E-mail</label><input type="email" name="email" value="<%= hospede.email %>" class="form-control"></div>
                    <div class="mb-3"><label class="form-label">Telefone</label><input type="text" name="telefone" value="<%= hospede.telefone %>" class="form-control"></div>
                    <div class="d-flex justify-content-between"><a href="/hospedes" class="btn btn-secondary">Voltar</a><button type="submit" class="btn btn-success">Atualizar</button></div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>