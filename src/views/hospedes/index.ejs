<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><title>Hóspedes - Hotel Twister</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4"><div class="container"><a class="navbar-brand" href="/dashboard">🏨 Hotel Twister</a><a href="/logout" class="btn btn-danger btn-sm">Sair</a></div></nav>
    <div class="container">
        <% if (erro === 'id_vinculado') { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <strong>Bloqueio de Exclusão!</strong> Este hóspede possui uma reserva ativa vinculada. Remova a reserva primeiro.
            </div>
        <% } %>
        <div class="d-flex justify-content-between mb-3"><h2>Gerenciamento de Hóspedes</h2><a href="/hospedes/novo" class="btn btn-primary">➕ Novo Hóspede</a></div>
        <table class="table table-striped table-hover shadow-sm bg-white rounded">
            <thead class="table-dark"><tr><th>Nome</th><th>CPF</th><th>E-mail</th><th>Telefone</th><th>Ações</th></tr></thead>
            <tbody>
                <% hospedes.forEach(h => { %>
                    <tr>
                        <td><%= h.nome %></td><td><%= h.cpf %></td><td><%= h.email %></td><td><%= h.telefone %></td>
                        <td>
                            <a href="/hospedes/editar/<%= h.id_hospede %>" class="btn btn-sm btn-warning">Editar</a>
                            <a href="/hospedes/excluir/<%= h.id_hospede %>" class="btn btn-sm btn-danger" onclick="return confirm('Confirmar exclusão?')">Excluir</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>